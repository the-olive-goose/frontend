# PostgreSQL connection string — provided automatically by Railway
DATABASE_URL=postgresql://user:password@host:port/dbname

# Your deployed frontend URL (e.g. https://the-olive-goose.up.railway.app)
FRONTEND_URL=https://your-frontend-url.com

# Strong random secret for signing JWTs
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret

# Admin login credentials
ADMIN_EMAIL=admin@yourdomain.com

# bcrypt hash of your admin password
# Generate with: node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$examplehashhere
